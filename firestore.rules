rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email == 'senuthbandara28@gmail.com') ||
        ('email' in request.auth.token && exists(/databases/$(database)/documents/admins/$(request.auth.token.email))) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }
    
    function isEditor() {
      return isSignedIn() && 'email' in request.auth.token && exists(/databases/$(database)/documents/editors/$(request.auth.token.email));
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidTeacher(data) {
      return data.name is string &&
             data.subjectId is string &&
             data.imageUrl is string &&
             data.description is string &&
             data.socials is map;
    }

    function isValidCourse(data) {
      return data.title is string &&
             data.subjectId is string &&
             data.teacherId is string &&
             data.subcategoryId is string &&
             data.unit is string &&
             data.thumbnailUrl is string &&
             data.views is number &&
             data.links is list;
    }

    function isValidAd(data) {
      return data.title is string &&
             data.teacherId is string &&
             data.imageUrl is string &&
             data.description is string;
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /editors/{editorId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidId(teacherId) && isValidTeacher(incoming());
      allow update: if isAdmin() && isValidId(teacherId) && isValidTeacher(incoming());
      allow delete: if isAdmin() && isValidId(teacherId);
    }

    match /courses/{courseId} {
      allow read: if true;
      allow list: if true;
      allow create: if (isAdmin() || isEditor()) && isValidId(courseId) && isValidCourse(incoming());
      allow update: if (isAdmin() || isEditor()) && isValidId(courseId) && isValidCourse(incoming());
      allow delete: if isAdmin() && isValidId(courseId);
    }

    match /ads/{adId} {
      allow read: if true;
      allow list: if true;
      allow create: if isAdmin() && isValidId(adId) && isValidAd(incoming());
      allow update: if isAdmin() && isValidId(adId) && isValidAd(incoming());
      allow delete: if isAdmin() && isValidId(adId);
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow list: if true;
      allow write: if isAdmin();
    }

    match /subcategories/{subcategoryId} {
      allow read: if true;
      allow list: if true;
      allow write: if isAdmin();
    }
  }
}
