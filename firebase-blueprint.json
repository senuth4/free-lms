{
  "entities": {
    "Teacher": {
      "title": "Teacher",
      "description": "Teacher profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "subjectId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "socials": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "subjectId", "imageUrl"]
    },
    "Course": {
      "title": "Course",
      "description": "Course information",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subjectId": { "type": "string" },
        "teacherId": { "type": "string" },
        "subcategoryId": { "type": "string" },
        "unit": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "views": { "type": "number" },
        "links": { "type": "array" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "subjectId", "teacherId", "thumbnailUrl"]
    },
    "Ad": {
      "title": "Ad",
      "description": "Hero Banner Advertisement",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "teacherId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "imageUrl"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Educational subject category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name"]
    },
    "Subcategory": {
      "title": "Subcategory",
      "description": "Course category",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/teachers/{teacherId}": {
      "schema": { "$ref": "#/entities/Teacher" },
      "description": "All teachers"
    },
    "/courses/{courseId}": {
      "schema": { "$ref": "#/entities/Course" },
      "description": "All courses"
    },
    "/ads/{adId}": {
      "schema": { "$ref": "#/entities/Ad" },
      "description": "All active ads"
    },
    "/subjects/{subjectId}": {
      "schema": { "$ref": "#/entities/Subject" },
      "description": "Available subjects"
    },
    "/subcategories/{subcategoryId}": {
      "schema": { "$ref": "#/entities/Subcategory" },
      "description": "Available course categories"
    }
  }
}
